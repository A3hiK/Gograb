<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light Theme Colors -->
    <SolidColorBrush x:Key="Blue" Color="#0876CC"/>
    <SolidColorBrush x:Key="BlueDark" Color="#065A9E"/>
    <SolidColorBrush x:Key="BlueLight" Color="#E5F1FB"/>
    <SolidColorBrush x:Key="Green" Color="#107C10"/>
    <SolidColorBrush x:Key="GreenLight" Color="#DFF6DD"/>
    <SolidColorBrush x:Key="Red" Color="#E81123"/>
    <SolidColorBrush x:Key="RedLight" Color="#FDE7E9"/>
    <SolidColorBrush x:Key="Orange" Color="#CA5010"/>
    <SolidColorBrush x:Key="OrangeLight" Color="#FFF4CE"/>
    <SolidColorBrush x:Key="BgToolbar" Color="#F3F3F3"/>
    <SolidColorBrush x:Key="BgPage" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BgItem" Color="#FAFAFA"/>
    <SolidColorBrush x:Key="Border" Color="#D1D1D1"/>
    <SolidColorBrush x:Key="BorderLight" Color="#E5E5E5"/>
    <SolidColorBrush x:Key="Text" Color="#1B1B1B"/>
    <SolidColorBrush x:Key="TextSec" Color="#616161"/>
    <SolidColorBrush x:Key="TextMuted" Color="#999999"/>
    <SolidColorBrush x:Key="PillOff" Color="#E8E8E8"/>
    <SolidColorBrush x:Key="PillOffText" Color="#616161"/>

    <!-- Window Background -->
    <SolidColorBrush x:Key="WindowBg" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="BtnBorder" Color="#C0C0C0"/>
    <SolidColorBrush x:Key="BtnIcon" Color="#555555"/>

    <!-- Light ComboBox -->
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="#1B1B1B"/>
        <Setter Property="BorderBrush" Value="#D1D1D1"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2" Padding="4,2">
                            <Grid>
                                <ContentPresenter x:Name="Content" Content="{TemplateBinding SelectionBoxItem}" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                <ToggleButton x:Name="DropDownBtn" IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}" Focusable="False" ClickMode="Press" HorizontalAlignment="Right" Width="16" Background="Transparent" BorderThickness="0">
                                    <Path x:Name="Arrow" Data="M 0 0 L 4 4 L 8 0 Z" Fill="#666666" Stretch="Uniform" Width="8" Height="4"/>
                                </ToggleButton>
                            </Grid>
                        </Border>
                        <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                            <Border Background="White" BorderBrush="#D1D1D1" BorderThickness="1" CornerRadius="2" Margin="0,2,0,0" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <ScrollViewer Margin="0,2">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#0876CC"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#1B1B1B"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#E5F1FB"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#0876CC"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Light ScrollBar -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="#F0F0F0"/>
        <Setter Property="Foreground" Value="#CCCCCC"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid x:Name="Bg" Background="{TemplateBinding Background}">
                        <Border x:Name="Track" Background="Transparent"/>
                        <Track x:Name="PART_Track" IsDirectionReversed="true">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border CornerRadius="4" Background="#CCCCCC" Margin="2"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Light TextBox -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="#1B1B1B"/>
        <Setter Property="BorderBrush" Value="#D1D1D1"/>
        <Setter Property="CaretBrush" Value="#1B1B1B"/>
    </Style>

    <Style TargetType="ContextMenu">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="#1B1B1B"/>
        <Setter Property="BorderBrush" Value="#D1D1D1"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="MinWidth" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Foreground" Value="#1B1B1B"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="10,3,14,3"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                        <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#E5E5E5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Light ToolTip -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="#1B1B1B"/>
        <Setter Property="BorderBrush" Value="#D1D1D1"/>
    </Style>

</ResourceDictionary>
