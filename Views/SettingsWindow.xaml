<Window x:Class="EasyDL.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:EasyDL.ViewModels"
        Title="Settings" Height="420" Width="450"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource WindowBg}"
        ResizeMode="NoResize">
    <Window.DataContext>
        <vm:SettingsViewModel/>
    </Window.DataContext>

        <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Row="0">
            <StackPanel Margin="5">

                <!-- Download folder -->
                <TextBlock Text="Download Folder" FontWeight="Bold" FontSize="12" Foreground="{DynamicResource Blue}" Margin="0,0,0,6"/>
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Save videos to:" VerticalAlignment="Center" Foreground="{DynamicResource Text}"/>
                    <TextBox Text="{Binding DownloadFolder}" Grid.Column="1" Margin="0,0,8,0" VerticalContentAlignment="Center" IsReadOnly="True"
                             Background="{DynamicResource BgItem}" Foreground="{DynamicResource Text}" BorderBrush="{DynamicResource Border}" BorderThickness="1"/>
                    <Button Content="Browse..." Grid.Column="2" Padding="10,4" Command="{Binding ChooseDownloadFolderCommand}"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="75" Margin="0,0,8,0" Padding="0,5" Click="OkButton_Click"
                    Background="{DynamicResource Blue}" Foreground="White" BorderThickness="0"/>
            <Button Content="Cancel" Width="75" Padding="0,5" Click="CancelButton_Click"
                    Background="{DynamicResource BgItem}" Foreground="{DynamicResource Text}" BorderBrush="{DynamicResource Border}" BorderThickness="1"/>
        </StackPanel>
    </Grid>
</Window>
