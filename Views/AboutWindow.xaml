<Window x:Class="EasyDL.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About" Height="320" Width="300"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource WindowBg}"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Background="{DynamicResource WindowBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource BgItem}" BorderBrush="{DynamicResource Border}" BorderThickness="1" Margin="10,10,10,4">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20,18">

                <Border Width="52" Height="52" Background="{DynamicResource Blue}" CornerRadius="12" Margin="0,0,0,10" HorizontalAlignment="Center">
                    <Grid Width="28" Height="28">
                        <Path Data="M 2 16 L 2 30 L 30 30 L 30 16 L 22 16 L 19 10 L 2 10 Z" Fill="Transparent" Stroke="White" StrokeThickness="2.5" StrokeLineJoin="Round"/>
                        <Path Data="M 16 2 L 16 22 M 10 16 L 16 22 L 22 16" Stroke="White" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"/>
                    </Grid>
                </Border>

                <TextBlock Text="Gograb" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Text}" HorizontalAlignment="Center"/>
                <TextBlock Text="YouTube Video &amp; Audio Downloader" FontSize="9" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" Margin="0,3,0,0"/>

                <Border Height="1" Background="{DynamicResource Border}" Margin="0,12"/>

                <Grid HorizontalAlignment="Center" Width="200">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Version:" Foreground="{DynamicResource TextMuted}" Width="60" FontSize="9" Margin="0,0,8,6"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="1.0.2" Foreground="{DynamicResource Text}" FontWeight="SemiBold" FontSize="9" Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Engine:" Foreground="{DynamicResource TextMuted}" Width="60" FontSize="9" Margin="0,0,8,6"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="yt-dlp + ffmpeg" Foreground="{DynamicResource Text}" FontWeight="SemiBold" FontSize="9" Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="License:" Foreground="{DynamicResource TextMuted}" Width="60" FontSize="9" Margin="0,0,8,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Open Source" Foreground="{DynamicResource Text}" FontWeight="SemiBold" FontSize="9"/>
                </Grid>

                <Border Height="1" Background="{DynamicResource Border}" Margin="0,12"/>

                <TextBlock TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource TextMuted}" FontSize="8.5" LineHeight="15" MaxWidth="220">
                    Download YouTube videos and audio in multiple resolutions with mobile phone conversion support.
                </TextBlock>

            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,2,10,8">
            <Button Content="Close" Width="70" Padding="0,4" Click="Close_Click" FontSize="9">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{DynamicResource Blue}" CornerRadius="3" Padding="10,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
