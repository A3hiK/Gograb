<Window x:Class="EasyDL.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:EasyDL.ViewModels"
        Title="Gograb - YouTube Downloader" Height="600" Width="420"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow" Background="{DynamicResource WindowBg}"
        MinHeight="420" MinWidth="420">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="LightTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

        <!-- Thin ProgressBar -->
        <Style TargetType="ProgressBar" x:Key="ThinProgress">
            <Setter Property="Height" Value="4"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- Circle Button - Theme Aware -->
        <Style TargetType="Button" x:Key="CircleBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BtnBorder}"/>
            <Setter Property="Foreground" Value="{DynamicResource BtnIcon}"/>
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="20" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.08" ScaleY="1.08"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource PillOff}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Delete Button -->
        <Style TargetType="Button" x:Key="DeleteBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource RedLight}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Red}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource Red}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon Button -->
        <Style TargetType="Button" x:Key="IconBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSec}"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource PillOff}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource Border}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Resolution Pill -->
        <Style TargetType="RadioButton" x:Key="ResolutionPill">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" Background="{DynamicResource PillOff}" BorderBrush="Transparent" BorderThickness="1" CornerRadius="3" Padding="5,2" Margin="0,0,3,2" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="txt" Text="{TemplateBinding Tag}" Foreground="{DynamicResource PillOffText}" FontSize="8" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <TextBlock x:Name="hd" Text=" HD" Foreground="{DynamicResource Red}" FontSize="6" FontWeight="Bold" VerticalAlignment="Center" Visibility="Collapsed" Margin="2,0,0,0"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource Blue}"/>
                                <Setter TargetName="txt" Property="Foreground" Value="White"/>
                                <Setter TargetName="hd" Property="Foreground" Value="#FFB3B3"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#B0B0B0"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="1080p">
                                <Setter TargetName="hd" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Audio Pill -->
        <Style TargetType="RadioButton" x:Key="AudioPill">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" Background="{DynamicResource OrangeLight}" BorderBrush="Transparent" BorderThickness="1" CornerRadius="4" Padding="7,3" Margin="0,0,4,3" Cursor="Hand">
                            <TextBlock x:Name="txt" Text="MP3" Foreground="{DynamicResource Orange}" FontSize="9" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource Orange}"/>
                                <Setter TargetName="txt" Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#D0D0D0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Status Filter Pill -->
        <Style TargetType="RadioButton" x:Key="StatusPill">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" Background="{DynamicResource PillOff}" BorderBrush="Transparent" BorderThickness="1" CornerRadius="12" Padding="12,4" Margin="0,0,5,0">
                            <TextBlock x:Name="txt" Text="{TemplateBinding Tag}" Foreground="{DynamicResource PillOffText}" FontSize="9" FontWeight="SemiBold"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource Blue}"/>
                                <Setter TargetName="txt" Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#B0B0B0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="34"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- ===== TOP TOOLBAR ===== -->
        <Border Grid.Row="0" Background="{DynamicResource BgToolbar}" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Paste Link -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                    <Button Style="{StaticResource CircleBtn}" Command="{Binding AddLinkCommand}" Width="26" Height="26">
                        <Path Data="M 2 6 L 10 6 M 6 2 L 6 10" Stroke="{DynamicResource BtnIcon}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Button>
                    <TextBlock Text="Paste link" FontSize="11" Foreground="{DynamicResource Text}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Resolution + Keypad Convert -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Res:" FontSize="10" Foreground="{DynamicResource TextSec}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox x:Name="ResCombo" Width="70" FontSize="10" SelectedIndex="1" SelectionChanged="ResCombo_SelectionChanged"
                              Background="{DynamicResource BgItem}" BorderBrush="{DynamicResource Border}" BorderThickness="1" Padding="3,2">
                        <ComboBoxItem Content="1080p"/>
                        <ComboBoxItem Content="720p"/>
                        <ComboBoxItem Content="480p"/>
                        <ComboBoxItem Content="320p"/>
                    </ComboBox>

                    <Border Width="1" Height="18" Background="{DynamicResource Border}" Margin="8,0"/>

                    <TextBlock Text="Mobile" FontSize="9" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="8,0,4,0"/>
                    <ToggleButton x:Name="ConvertToggle" Width="30" Height="16" Checked="ConvertToggle_Changed" Unchecked="ConvertToggle_Changed" VerticalAlignment="Center">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="thumb" Background="#D0D0D0" CornerRadius="8" Padding="1.5" BorderBrush="{DynamicResource BtnBorder}" BorderThickness="0.5">
                                    <Border x:Name="knob" Background="White" CornerRadius="6" HorizontalAlignment="Left" Width="13" Height="13" BorderBrush="#D0D0D0" BorderThickness="0.5">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="2" ShadowDepth="0.5" Color="#000000" Opacity="0.1"/>
                                        </Border.Effect>
                                    </Border>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="thumb" Property="Background" Value="#0876CC"/>
                                        <Setter TargetName="thumb" Property="BorderBrush" Value="#065A9E"/>
                                        <Setter TargetName="knob" Property="HorizontalAlignment" Value="Right"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="thumb" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                </StackPanel>

                <!-- Download All -->
                <Button Grid.Column="2" Style="{StaticResource CircleBtn}" Command="{Binding DownloadAllCommand}" Margin="10,0,0,0">
                    <Path Data="M 2 8 L 7 13 L 12 8 M 7 1 L 7 13" Stroke="{DynamicResource BtnIcon}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"/>
                </Button>
            </Grid>
        </Border>

        <!-- ===== STATUS FILTER PILLS ===== -->
        <Border Grid.Row="1" Background="{DynamicResource BgToolbar}" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                <RadioButton x:Name="PillAll" Tag="All" Click="StatusPill_Click" IsChecked="True">
                    <RadioButton.Style>
                        <Style TargetType="RadioButton">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="bd" Background="{DynamicResource PillOff}" BorderBrush="Transparent" BorderThickness="1" CornerRadius="12" Padding="12,4" Margin="0,0,5,0">
                                            <TextBlock x:Name="txt" Text="{Binding DataContext.PillAllText, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{DynamicResource PillOffText}" FontSize="9" FontWeight="SemiBold"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource Blue}"/>
                                                <Setter TargetName="txt" Property="Foreground" Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#B0B0B0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </RadioButton.Style>
                </RadioButton>
                <RadioButton x:Name="PillProcessing" Tag="Processing" Click="StatusPill_Click">
                    <RadioButton.Style>
                        <Style TargetType="RadioButton">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="bd" Background="{DynamicResource PillOff}" BorderBrush="Transparent" BorderThickness="1" CornerRadius="12" Padding="12,4" Margin="0,0,5,0">
                                            <TextBlock x:Name="txt" Text="{Binding DataContext.PillProcessingText, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{DynamicResource PillOffText}" FontSize="9" FontWeight="SemiBold"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource Blue}"/>
                                                <Setter TargetName="txt" Property="Foreground" Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#B0B0B0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </RadioButton.Style>
                </RadioButton>
                <RadioButton x:Name="PillFailed" Tag="Failed" Click="StatusPill_Click">
                    <RadioButton.Style>
                        <Style TargetType="RadioButton">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="bd" Background="{DynamicResource PillOff}" BorderBrush="Transparent" BorderThickness="1" CornerRadius="12" Padding="12,4" Margin="0,0,5,0">
                                            <TextBlock x:Name="txt" Text="{Binding DataContext.PillFailedText, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{DynamicResource PillOffText}" FontSize="9" FontWeight="SemiBold"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource Blue}"/>
                                                <Setter TargetName="txt" Property="Foreground" Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#B0B0B0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </RadioButton.Style>
                </RadioButton>
                <RadioButton x:Name="PillSkipped" Tag="Skipped" Click="StatusPill_Click">
                    <RadioButton.Style>
                        <Style TargetType="RadioButton">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="bd" Background="{DynamicResource PillOff}" BorderBrush="Transparent" BorderThickness="1" CornerRadius="12" Padding="12,4" Margin="0,0,5,0">
                                            <TextBlock x:Name="txt" Text="{Binding DataContext.PillSkippedText, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{DynamicResource PillOffText}" FontSize="9" FontWeight="SemiBold"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource Blue}"/>
                                                <Setter TargetName="txt" Property="Foreground" Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#B0B0B0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </RadioButton.Style>
                </RadioButton>
                <RadioButton x:Name="PillComplete" Tag="Complete" Click="StatusPill_Click">
                    <RadioButton.Style>
                        <Style TargetType="RadioButton">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="bd" Background="{DynamicResource PillOff}" BorderBrush="Transparent" BorderThickness="1" CornerRadius="12" Padding="12,4" Margin="0,0,5,0">
                                            <TextBlock x:Name="txt" Text="{Binding DataContext.PillCompleteText, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{DynamicResource PillOffText}" FontSize="9" FontWeight="SemiBold"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource Blue}"/>
                                                <Setter TargetName="txt" Property="Foreground" Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#B0B0B0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </RadioButton.Style>
                </RadioButton>
            </StackPanel>
        </Border>

        <!-- ===== MAIN QUEUE AREA ===== -->
        <Border Grid.Row="2" Background="{DynamicResource BgPage}" BorderThickness="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" BorderThickness="0">
                <ItemsControl ItemsSource="{Binding FilteredView}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource BgItem}" BorderBrush="{DynamicResource BorderLight}" BorderThickness="0,0,0,1" Padding="8,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Thumbnail -->
                                    <Border Grid.Column="0" Width="80" Height="45" Background="#1B1B1B" CornerRadius="3" Margin="0,0,8,0" ClipToBounds="True" Cursor="Hand" MouseLeftButtonUp="Thumbnail_Click" MouseRightButtonDown="Thumbnail_RightClick">
                                        <Grid>
                                            <Image Source="{Binding ThumbnailUrl}" Stretch="UniformToFill"/>
                                            <Border HorizontalAlignment="Left" VerticalAlignment="Bottom" Background="{DynamicResource Red}" Width="14" Height="10" Margin="2,0,0,2">
                                                <Path Data="M 3 1.5 L 3 8.5 L 10 5 Z" Fill="White" Stretch="Uniform" Width="4" Height="4" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="#000000CC" CornerRadius="2" Padding="3,1" Margin="0,0,2,2">
                                                <TextBlock Text="{Binding Duration}" Foreground="White" FontSize="7" FontWeight="SemiBold"/>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- Info + Pills -->
                                    <Grid Grid.Column="1" VerticalAlignment="Center">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="10" Foreground="{DynamicResource Text}" TextTrimming="CharacterEllipsis" Margin="0,0,0,3" FontWeight="SemiBold"/>

                                        <!-- Resolution Pills -->
                                        <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,4">
                                            <RadioButton Tag="1080p" Click="ResolutionPill_Click">
                                                <RadioButton.Style>
                                                    <Style TargetType="RadioButton" BasedOn="{StaticResource ResolutionPill}">
                                                        <Setter Property="IsChecked" Value="False"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedResolution}" Value="1080p">
                                                                <Setter Property="IsChecked" Value="True"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </RadioButton.Style>
                                            </RadioButton>
                                            <RadioButton Tag="720p" Click="ResolutionPill_Click">
                                                <RadioButton.Style>
                                                    <Style TargetType="RadioButton" BasedOn="{StaticResource ResolutionPill}">
                                                        <Setter Property="IsChecked" Value="False"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedResolution}" Value="720p">
                                                                <Setter Property="IsChecked" Value="True"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </RadioButton.Style>
                                            </RadioButton>
                                            <RadioButton Tag="480p" Click="ResolutionPill_Click">
                                                <RadioButton.Style>
                                                    <Style TargetType="RadioButton" BasedOn="{StaticResource ResolutionPill}">
                                                        <Setter Property="IsChecked" Value="False"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedResolution}" Value="480p">
                                                                <Setter Property="IsChecked" Value="True"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </RadioButton.Style>
                                            </RadioButton>
                                            <RadioButton Tag="320p" Click="ResolutionPill_Click">
                                                <RadioButton.Style>
                                                    <Style TargetType="RadioButton" BasedOn="{StaticResource ResolutionPill}">
                                                        <Setter Property="IsChecked" Value="False"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedResolution}" Value="320p">
                                                                <Setter Property="IsChecked" Value="True"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </RadioButton.Style>
                                            </RadioButton>
                                            <RadioButton Tag="Audio (MP3)" Click="ResolutionPill_Click">
                                                <RadioButton.Style>
                                                    <Style TargetType="RadioButton" BasedOn="{StaticResource AudioPill}">
                                                        <Setter Property="IsChecked" Value="False"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedResolution}" Value="Audio (MP3)">
                                                                <Setter Property="IsChecked" Value="True"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </RadioButton.Style>
                                            </RadioButton>
                                        </WrapPanel>

                                        <!-- Progress + Status -->
                                        <StackPanel Grid.Row="2">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Status}" FontSize="7.5" Foreground="{DynamicResource TextMuted}" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock FontSize="7.5" Foreground="{DynamicResource Green}" FontWeight="SemiBold" Margin="3,0,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Setter Property="Text" Value="{Binding Progress, StringFormat='{}{0:0}%', Mode=OneWay}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Downloading">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Converting for mobile (128x160)...">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Eta}" FontSize="7" Foreground="{DynamicResource Red}" TextTrimming="CharacterEllipsis" MaxWidth="260" Margin="0,1,0,0" ToolTip="{Binding Eta}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Error">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Actions -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top" Margin="6,6,0,0">
                                        <Button Style="{StaticResource DeleteBtn}" Click="DeleteBtn_Click" ToolTip="Remove" Width="18" Height="18">
                                            <Canvas Width="10" Height="10">
                                                <Line X1="1" Y1="1" X2="9" Y2="9" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5"/>
                                                <Line X1="9" Y1="1" X2="1" Y2="9" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5"/>
                                            </Canvas>
                                        </Button>
                                        <Button Click="DownloadBtn_Click" Width="22" Height="22" Margin="4,0,0,0" ToolTip="Download">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource CircleBtn}"/>
                                            </Button.Style>
                                            <Grid>
                                                <!-- Download Arrow -->
                                                <Path Data="M 1 8 L 5 8 L 5 1 L 7 1 L 7 8 L 11 8 L 6 13 Z" Fill="{DynamicResource BtnIcon}">
                                                    <Path.Style>
                                                        <Style TargetType="Path">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Downloading">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Converting for mobile (128x160)...">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Path.Style>
                                                </Path>
                                                <!-- Stop Square -->
                                                <Border Width="8" Height="8" Background="{DynamicResource BtnIcon}" CornerRadius="1">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Downloading">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Converting for mobile (128x160)...">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>
                                            </Grid>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ===== BOTTOM BAR ===== -->
        <Border Grid.Row="3" Background="{DynamicResource BgToolbar}" BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource CircleBtn}" Click="About_Click" Width="22" Height="22" ToolTip="About">
                        <TextBlock Text="&#x24D8;" FontSize="11" Foreground="{DynamicResource BtnIcon}"/>
                    </Button>
                    <Button Style="{StaticResource CircleBtn}" Click="Folder_Click" Width="22" Height="22" Margin="4,0,0,0" ToolTip="Download folder">
                        <Path Data="M 1 3 L 1 9 L 9 9 L 9 3 L 6 3 L 5 1.5 L 1 1.5 Z" Stroke="{DynamicResource BtnIcon}" StrokeThickness="1" Fill="Transparent" StrokeLineJoin="Round"/>
                    </Button>
                    <Button Style="{StaticResource CircleBtn}" Click="ClearCompleted_Click" Width="22" Height="22" Margin="4,0,0,0" ToolTip="Clear completed">
                        <Path Data="M 2 3 L 10 3 M 3 3 L 3 9 L 9 9 L 9 3 M 4 4.5 L 4 8 M 6 4.5 L 6 8 M 8 4.5 L 8 8" Stroke="{DynamicResource BtnIcon}" StrokeThickness="0.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                    </Button>
                    <TextBlock Text="Gograb v1.0" FontSize="8" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="5,0,0,0"/>
                </StackPanel>

                <!-- Dark Mode Toggle -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Cursor="Hand">
                    <ToggleButton x:Name="DarkModeToggle" Width="34" Height="18" Checked="DarkModeToggle_Changed" Unchecked="DarkModeToggle_Changed" VerticalAlignment="Center">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="thumb" Background="#D0D0D0" CornerRadius="9" Padding="2" BorderBrush="#C0C0C0" BorderThickness="0.5">
                                    <Border x:Name="knob" Background="White" CornerRadius="7" HorizontalAlignment="Left" Width="14" Height="14" BorderBrush="#D0D0D0" BorderThickness="0.5">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="2" ShadowDepth="1" Color="#000000" Opacity="0.12"/>
                                        </Border.Effect>
                                    </Border>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="thumb" Property="Background" Value="#0876CC"/>
                                        <Setter TargetName="thumb" Property="BorderBrush" Value="#065A9E"/>
                                        <Setter TargetName="knob" Property="HorizontalAlignment" Value="Right"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="thumb" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                    <TextBlock Text="Dark" FontSize="9" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

